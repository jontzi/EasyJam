PORT=5050
FRONTEND_URL=http://localhost:5173
DATABASE_PATH=./data/easyjam.sqlite

# Create these in the Spotify Developer Dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5050/api/auth/callback

# Optional: use an existing host-owned playlist instead of creating one.
SPOTIFY_PLAYLIST_ID=

# Optional: keep Spotify on the EasyJam playlist automatically. Set false for manual host playback.
AUTO_START_PLAYBACK=true
